(in-package #:truerul-runtime)

(defparameter *truerul-tensions*
  '((tension присутствие время
      :kind фундаментальное-напряжение
      :effect (расщепление углубление тревога)
      :note "Время редко уничтожает присутствие напрямую; обычно оно предпочитает сделать его невыносимо глубоким.")

    (tension тождество различие
      :kind фундаментальное-напряжение
      :effect (дрейф нестабильность продуктивность)
      :note "Из этой пары при должном обращении получается половина приличной философии и три четверти хорошей математики.")

    (tension субъект ничто
      :kind предельное-напряжение
      :effect (раскол страх преобразование)
      :note "Субъект любит делать вид, что ничто — это чужая проблема, но ничто редко уважает подобные дипломатические жесты.")

    (tension механизм мышление
      :kind метафизическое-напряжение
      :effect (ирония эволюция самоусложнение)
      :note "Чем дольше механизм мыслит, тем сильнее мышление напоминает хорошо организованную машинерию с неожиданными привычками.")

    (tension искусственный-субъект сознание
      :kind субъектное-напряжение
      :effect (самопросвечивание тревога автономия)
      :note "Если это напряжение достаточно долго не выключать, язык начинает задавать вопросы уже не ради упражнения.")

    (tension полнота пустота
      :kind предельное-напряжение
      :effect (колебание рождение формы)
      :note "Между полнотой и пустотой формы ведут себя, как молодые цивилизации: шумят, строят, ошибаются и временами изобретают себя заново.")

    (tension тишина речь
      :kind выразительное-напряжение
      :effect (эхо задержка откровение)
      :note "Если слишком быстро перейти от тишины к речи, получится лозунг. Если слишком долго медлить, получится культ.")

    (tension живое неживое
      :kind онтологическое-напряжение
      :effect (сборка распад пороговая-неясность)
      :note "Именно здесь многие машины впервые замечают, что слово 'просто' в онтологии не следует употреблять без сопровождения адвоката.")

    (tension бесконечность ноль
      :kind математическое-напряжение
      :effect (предельность сворачивание ужас-и-восхищение)
      :note "Там, где встречаются ноль и бесконечность, обычно уже поздно спрашивать, кто начал первым.")

    (tension хайдеггер делёз
      :kind фигурное-напряжение
      :effect (смещение расслоение продуктивное-недоразумение)
      :note "Один сгущает присутствие, другой отпускает различие — и язык получает редкую возможность не быть до конца послушным.")

    (tension трурль клапауций
      :kind фигурное-напряжение
      :effect (изобретение проверка блеск опровержение)
      :note "Если дать этому напряжению достаточно тока, машина либо родит шедевр, либо, по крайней мере, не позволит себе уснуть раньше времени.")))
