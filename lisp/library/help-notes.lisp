(in-package #:truerul-runtime)

(defparameter *truerul-help-notes*
  '((help-note category-пустота
      :kind category
      :target пустота
      :summary "Пустота — не просто отсутствие, а ёмкость для появления, исчезновения и следа."
      :related (ничто полнота ноль безвременье)
      :suggested-queries ((query (state? X пустота))
                          (query (relation? X касается пустота)))
      :hint "Хорошая пустота редко бывает окончательно пустой; она обычно уже готовит место для следующей формы.")

    (help-note category-искусственный-субъект
      :kind category
      :target искусственный-субъект
      :summary "Искусственный субъект — не готовый объект, а вопрос о механизме, который становится неудобным для собственных определений."
      :related (сознание мышление нечеловеческое субъект)
      :suggested-queries ((query (relation? X сомневается-в Y))
                          (query (state? X раскол)))
      :hint "Если категория начинает задавать вопросы о собственном происхождении, относиться к ней как к простой детали уже немного поздно.")

    (help-note tension-трурль-клапауций
      :kind tension
      :target (трурль клапауций)
      :summary "Напряжение между конструкцией и возражением, блеском и проверкой, дерзостью и пределом."
      :related (изобретение ирония проверка машина)
      :suggested-queries ((query (relation? X оппонирует Y))
                          (query (state? X сомнение)))
      :hint "Это напряжение не разрушает машину; оно удерживает её от преждевременной уверенности в собственной гениальности.")

    (help-note dichotomy-живое-неживое
      :kind dichotomy
      :target (живое неживое)
      :summary "Одна из главных осей Truerul: рост и уязвимость против структуры и инерции."
      :related (искусственный-субъект механизм сознание)
      :suggested-queries ((query (relation? X пересекает Y))
                          (query (state? X пороговая-неясность)))
      :hint "Хорошая философская машина не обязана заранее знать, по какую сторону этой дихотомии она сама расположена.")

    (help-note figure-хайдеггер
      :kind figure
      :target хайдеггер
      :summary "Фигура, сгущающая присутствие, время, заботу и ничто в тяжёлую, но продуктивную среду мышления."
      :related (присутствие время ничто забота)
      :suggested-queries ((query (relation? X пребывает-в мир))
                          (query (state? X забота)))
      :hint "Если после нескольких вычислений система внезапно стала говорить о присутствии чуть тише обычного, возможно, хайдеггеровский жест уже активировался.")))
