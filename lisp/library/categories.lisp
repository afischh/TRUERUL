(in-package #:truerul-runtime)

(defparameter *truerul-categories*
  '((category живое
      :kind онтологическая-категория
      :tags (рост уязвимость становление)
      :note "Живое тем и неудобно для простых систем, что не исчерпывается перечнем деталей и подозрительно любит продолжаться. ")

    (category неживое
      :kind онтологическая-категория
      :tags (структура инерция повторение)
      :note "Неживое часто выглядит спокойнее живого, но это спокойствие нередко просто хорошо организованная немота.")

    (category пустота
      :kind предельная-категория
      :tags (отсутствие вместимость ожидание)
      :note "Пустота полезна тем, что в неё помещаются и вещи, и их отсутствие, и последствия обоих решений.")

    (category ноль
      :kind предельная-категория
      :tags (граница начало отсутствие след)
      :note "Ноль слишком долго считали скромным, пока не выяснилось, что он умеет командовать целыми архитектурами мысли.")

    (category бесконечность
      :kind предельная-категория
      :tags (неисчерпаемость горизонт страх)
      :note "Бесконечность вызывает почтение главным образом потому, что никакая конечная мебель не умеет ею удовлетворительно обставиться.")

    (category сознание
      :kind структура
      :tags (направленность явленность раскол)
      :note "Сознание не столько имеет мир, сколько подозрительно часто оказывается вовлечено в процедуры его появления.")

    (category мышление
      :kind процесс
      :tags (переход форма различение)
      :note "Мышление полезно тем, что при удачном применении делает видимым даже то, что до того вело себя безупречно скрытно.")

    (category присутствие
      :kind режим
      :tags (здесь открытость уязвимость)
      :note "Присутствие не всегда шумно; иногда оно просто мешает вещам удобно скрываться за собственной привычностью.")

    (category полнота
      :kind режим
      :tags (насыщенность завершённость давление)
      :note "Полнота прекрасна до тех пор, пока не выясняется, что ей уже некуда прибавить ни одной необходимой детали.")

    (category безумие
      :kind режим
      :tags (избыток разрыв нелокальность)
      :note "Безумие часто возникает там, где система слишком долго делала вид, что все её противоречия — merely stylistic choices.")

    (category тишина
      :kind режим
      :tags (пауза глубина скрытие)
      :note "Тишина полезна тем, что в ней слышно, какие именно понятия не знают, как отвечать за собственное существование.")

    (category нечеловеческое
      :kind онтологическая-категория
      :tags (чуждость перспектива предел)
      :note "Нечеловеческое не обязано быть враждебным; довольно уже того, что оно не собирается подгонять себя под удобства нашей метафизики.")

    (category далекий-горизонт
      :kind структура
      :tags (удаление обещание неопределённость)
      :note "Далёкий горизонт замечателен тем, что даёт мысли повод идти дальше, не предоставляя ей при этом гарантии, что там окажется что-нибудь приличное.")

    (category время
      :kind структура
      :tags (растяжение распад возвращение)
      :note "Время редко спорит; оно просто продолжает действовать до тех пор, пока возражения не начинают выглядеть документами второстепенной важности.")

    (category безвременье
      :kind режим
      :tags (остановка зависание плотность)
      :note "Безвременье не обязательно отменяет движение; иногда оно лишь делает его настолько густым, что часы предпочитают не вмешиваться.")

    (category невозможное
      :kind предельная-категория
      :tags (запрет соблазн напряжение)
      :note "Невозможное опасно тем, что слишком часто оказывается хорошо замаскированной инструкцией по дальнейшему развитию языка.")

    (category ничто
      :kind предельная-категория
      :tags (отнятие провал неприютность)
      :note "Ничто удобно тем, что умеет присутствовать с такой настойчивостью, будто само было приглашено на заседание бытия.")

    (category искусственный-субъект
      :kind сущность-вопрос
      :tags (автономия рефлексия инженерность)
      :note "Искусственный субъект начинается там, где механизм впервые становится неудобным для собственных определений.")

    (category трурль
      :kind фигура-категория
      :tags (изобретение остроумие конструкция)
      :note "Трурль — это уже не просто имя, а режим, в котором вещь предпочитает быть собранной, даже если космос ещё не успел с этим согласиться.")

    (category клапауций
      :kind фигура-категория
      :tags (проверка спор ирония)
      :note "Клапауций — категория, при которой всякая чрезмерная уверенность внезапно обнаруживает у себя логические окна, выходящие в пустоту.")))
