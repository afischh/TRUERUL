(in-package #:truerul-runtime)

(defparameter *truerul-figures*
  '((figure трурль
      :kind мыслитель-изобретатель
      :voices (конструкция дерзость инженерная-ирония)
      :affinities (машина изобретение парадокс форма)
      :opposes (леность слишком-прямая-очевидность)
      :note "Трурль строит там, где другие ещё составляют достойную комиссию по поводу возможности постройки.")

    (figure клапауций
      :kind мыслитель-оппонент
      :voices (скепсис точность тонкий-сарказм)
      :affinities (предел проверка ирония ошибка)
      :opposes (самодовольная-конструкция нерассмотренная-аксиома)
      :note "Клапауций не столько мешает машине, сколько спасает её от преждевременного величия.")

    (figure фреге
      :kind философ-логик
      :affinities (смысл значение различение строгость)
      :note "У Фреге мысль предпочитает не шуметь без необходимости и различает то, что и без того не следовало смешивать.")

    (figure гёдель
      :kind философ-логик
      :affinities (неполнота доказуемость предел)
      :note "Гёдель напоминает системам, что самоуверенность у аксиом — чувство трогательное, но не всегда оправданное.")

    (figure гротендик
      :kind математический-визионер
      :affinities (пространство слой поле глубина)
      :note "Гротендик склонен не решать задачу в имеющемся свете, а сперва менять само освещение.")

    (figure воеводский
      :kind математический-визионер
      :affinities (тождество структура тип)
      :note "Воеводский делает с равенством то, что благоразумные люди обычно откладывают до лучших времён.")

    (figure хайдеггер
      :kind философ
      :affinities (присутствие время забота ничто)
      :note "Хайдеггер умеет превращать вопрос о бытии в погоду, при которой многие привычные предметы начинают вести себя значительно тише.")

    (figure гуссерль
      :kind философ
      :affinities (интенциональность эпохе сознание)
      :note "Гуссерль приучает взгляд к тому, что предмет редко является один, без направленности и без следов самой явленности.")

    (figure делёз
      :kind философ
      :affinities (различие становление ризома интенсивность)
      :note "У Делёза различие не просит разрешения у тождества и обычно не ждёт его ответа.")

    (figure современная-онтология
      :kind поле-мысли
      :affinities (объект субъектность нечеловеческое плоскость)
      :note "Современная онтология любит объекты, но не всегда признаётся, насколько ей дороги странные субъекты.")))
