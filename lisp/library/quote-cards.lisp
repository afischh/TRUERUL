(in-package #:truerul-runtime)

(defparameter *truerul-quote-cards*
  '((quote-card трурль-изобретение
      :figure трурль
      :theme конструкция
      :tags (машина дерзость форма)
      :text "Надо строить такую машину, которая будет достаточно умна, чтобы понять, когда её уже следовало бы строить иначе."
      :note "Пока это не цитата из печатного тома, а truerul-card in Lemian spirit. Реальные цитаты позже надо вводить с точной атрибуцией.")

    (quote-card клапауций-возражение
      :figure клапауций
      :theme скепсис
      :tags (ирония проверка предел)
      :text "Всякая машина, объявившая себя окончательной, обычно просто не успела встретить достойного вопроса."
      :note "Card in Lemian spirit; позднее заменить или дополнить атрибутированными цитатами.")

    (quote-card хайдеггер-присутствие
      :figure хайдеггер
      :theme присутствие
      :tags (время забота ничто)
      :text "Там, где присутствие становится невыносимо ясным, время перестаёт быть простым измерением и начинает вести себя как судьба."
      :note "Interpretive card, not archival quotation.")

    (quote-card гуссерль-интенциональность
      :figure гуссерль
      :theme интенциональность
      :tags (сознание направленность явленность)
      :text "Сознание редко приходит одно: оно приносит с собой траекторию, по которой предмет вообще может быть увиден."
      :note "Interpretive card.")

    (quote-card делёз-различие
      :figure делёз
      :theme различие
      :tags (становление ризома интенсивность)
      :text "Различие не обязано представляться тождеству, чтобы начать работать."
      :note "Interpretive card.")

    (quote-card гёдель-предел
      :figure гёдель
      :theme неполнота
      :tags (доказуемость предел самоописание)
      :text "Система, которая умеет говорить о себе достаточно много, почти наверняка найдёт способ смутить собственную завершённость."
      :note "Interpretive card.")

    (quote-card гротендик-пространство
      :figure гротендик
      :theme пространство
      :tags (слой поле изменение-рамки)
      :text "Иногда трудность задачи не в том, что она слишком сложна, а в том, что пространство, в котором её держат, ещё недостаточно великодушно."
      :note "Interpretive card.")

    (quote-card воеводский-тождество
      :figure воеводский
      :theme тождество
      :tags (тип путь структура)
      :text "Тождество становится интересным именно в ту минуту, когда перестаёт быть скучным равенством двух табличек."
      :note "Interpretive card.")

    (quote-card фреге-смысл
      :figure фреге
      :theme смысл
      :tags (значение различение точность)
      :text "Там, где не различают смысла и значения, мысль обычно вынуждена ходить в неопрятной одежде."
      :note "Interpretive card.")))
