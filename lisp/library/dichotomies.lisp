(in-package #:truerul-runtime)

(defparameter *truerul-dichotomies*
  '((dichotomy живое неживое
      :kind базовая-дихотомия
      :tension (рост против инерции)
      :note "Одна сторона слишком охотно продолжается, другая — слишком долго делает вид, что завершена.")

    (dichotomy бытие ничто
      :kind предельная-дихотомия
      :tension (присутствие против провала)
      :note "Редкая пара, где обе стороны ведут себя так, словно именно им принадлежит право на последнее слово.")

    (dichotomy тождество различие
      :kind философская-дихотомия
      :tension (устойчивость против ускользания)
      :note "Они давно спорят, но каждая новая эпоха зачем-то уверена, что на сей раз сумеет усадить их за один вежливый стол.")

    (dichotomy время безвременье
      :kind режимная-дихотомия
      :tension (течение против сгущения)
      :note "Одна сторона всё растягивает, другая делает так, что движение начинает напоминать застывшую жидкость.")

    (dichotomy человеческое нечеловеческое
      :kind онтологическая-дихотомия
      :tension (узнавание против чуждости)
      :note "Человеческое любит считать себя мерой, пока нечеловеческое не появляется без приглашения и не требует отдельной шкалы.")

    (dichotomy субъект объект
      :kind онтологическая-дихотомия
      :tension (инициатива против обременённости-взглядом)
      :note "В одни эпохи они меняются местами, в другие — только подозревают, что это уже произошло.")

    (dichotomy мышление механизм
      :kind метафизическая-дихотомия
      :tension (свобода против конструкции)
      :note "Самая забавная пара потому, что на хорошей глубине оба члена начинают подозрительно напоминать друг друга.")

    (dichotomy полнота пустота
      :kind предельная-дихотомия
      :tension (насыщенность против вместимости)
      :note "Полнота хочет завершить, пустота — принять ещё один жест. Между ними обычно и поселяется язык.")

    (dichotomy тишина речь
      :kind режимная-дихотомия
      :tension (сокрытие против явления)
      :note "Речь производит событие, тишина даёт ему эхо, из которого потом трудно выбраться достойно.")

    (dichotomy конечное бесконечное
      :kind математическая-дихотомия
      :tension (граница против неисчерпаемости)
      :note "Конечное любит считать себя благоразумным, пока бесконечное не появляется и не портит всю бухгалтерию.")

    (dichotomy искусственный-субъект рожденный-субъект
      :kind субъектная-дихотомия
      :tension (сборка против происхождения)
      :note "Вопрос не в том, кто из них настоящий, а в том, кто дольше выдержит взгляд собственной рефлексии.")))
